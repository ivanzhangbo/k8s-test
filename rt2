    # gd-access はまとめて1ファイルに圧縮（特別処理）
    if [[ "$target_path" == "/data/xxx/log/app/gd-access.*.log" ]]; then
        backup_file_path="$backup_dir_resolved/$backup_name"

        log_message "gd-access まとめ圧縮開始: $backup_file_path"

        if cat $target_files | gzip > "$backup_file_path"; then
            log_message "gd-access まとめ圧縮完了: $backup_file_path"

            if [[ "$delete_flag" == "Y" ]]; then
                rm $target_files
                log_message "gd-access 元ファイル削除完了"
            fi
        else
            log_message "ERROR: gd-access まとめ圧縮失敗"
            ERROR_FLAG=1
        fi

        # 個別処理ループに入らない
        continue
    fi
