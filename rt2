apiVersion: v1
kind: Pod
metadata:
  name: filestore-test
spec:
  containers:
  - name: app
    image: busybox
    command: ["sh", "-c", "sleep 3600"]
    volumeMounts:
    - mountPath: /mnt/filestore
      name: filestore-vol
  volumes:
  - name: filestore-vol
    persistentVolumeClaim:
      claimName: filestore-pvc
