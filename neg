apiVersion: v1
kind: Service
metadata:
  name: my-nginx-service
  annotations:
    cloud.google.com/neg: '{"exposed_ports": {"443":{}}}'
spec:
  type: ClusterIP
  selector:
    app: my-nginx
  ports:
  - name: https
    port: 443        # 必须与上方 exposed_ports 中的端口一致
    targetPort: 443  # Pod 监听的端口
    protocol: TCP
